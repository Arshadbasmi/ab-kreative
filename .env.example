# AB Kreative - Environment Variables
# Copy this file as .env and update the values

# === TURSO CLOUD DATABASE (for Vercel deployment) ===
# Get these from: https://turso.tech -> Dashboard -> Your Database
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# === LOCAL SQLITE (for local development) ===
DATABASE_URL="file:./db/custom.db"

# === PERMANENT SERVER EMAIL CONFIG ===
# Add these in Vercel Environment Variables for Production and Preview.
# Use route-specific variables when each category has its own mailbox.
DESIGN_SMTP_HOST=mail.abkreative.com
DESIGN_SMTP_PORT=465
DESIGN_SMTP_USER=design@abkreative.com
DESIGN_SMTP_PASS=your-design-mailbox-password
DESIGN_FROM_EMAIL=design@abkreative.com
DESIGN_FROM_NAME=Arshad

FITOUT_SMTP_HOST=mail.abkreative.com
