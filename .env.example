FITOUT_SMTP_USER=fitout@abkreative.com
FITOUT_SMTP_PASS=your-fitout-mailbox-password
FITOUT_FROM_EMAIL=fitout@abkreative.com
FITOUT_FROM_NAME=Ab Kreative Design & Fitout

